/delete-node/ &slot0_appcpu_partition;
/delete-node/ &slot1_partition;
/delete-node/ &slot1_appcpu_partition;
/delete-node/ &slot0_lpcore_partition;
/delete-node/ &slot1_lpcore_partition;
/delete-node/ &storage_partition;
/delete-node/ &scratch_partition;
/delete-node/ &coredump_partition;

&flash0
{
    reg = <0x0 DT_SIZE_M(16)>; // Address, size (16MB)

    partitions {
        slot0_partition: partition@20000
		{
            label = "image-0";
            reg = <0x20000 DT_SIZE_K(512)>;
            read-only;
        };
        game_settings_partition: partition@a0000
		{
            compatible = "zephyr,mapped-partition";
            label = "game-settings-partition";
            reg = <0xa0000 0x1000>;
        };
        game_saves_partition: partition@a1000
		{
            compatible = "zephyr,mapped-partition";
            label = "game-saves-partition";
            reg = <0xa1000 0x1000>;
        };
        cache_partition: partition@a2000
		{
            compatible = "zephyr,mapped-partition";
            label = "cache-partition";
            reg = <0xa2000 (0x22b000 - 0xa2000)>;
        };
        wad_partition: partition@22b000
		{
            compatible = "zephyr,mapped-partition";
            label = "wad-partition";
            reg = <0x22b000 (DT_SIZE_M(16) - 0x22b000)>;
            read-only;
        };
    };
};

&lcd_cam
{
    status = "okay";
};

/*
 * Third display path: upstream LCD-CAM i80 driver (drivers/mipi_dbi/mipi_dbi_esp32.c,
 * compatible "espressif,esp32-lcd-cam-mipi-dbi").
 *
 * Unlike the `testing` (espressif,esp-mipi-dbi-lcd) and `mipi_dbi`
 * (zephyr,mipi-dbi-bitbang) nodes above, this driver is NOT a top-level node:
 * it reads DT_INST_PARENT for IRQ / DMA (tx) / clocks, so the controller must be a
 * CHILD of &lcd_cam. The board stubs it as `lcd_cam_disp` (status disabled).
 *
 * Data(D0..D7) / WR(PCLK) / DC pins are routed via the lcd_cam pinctrl group below.
 * CS and reset are plain GPIOs on the controller node. RD (gpio0 9) is unused (i80 write-only).
 *
 * To use: comment out the `testing` node + its `aliases { display-ctrl = &st7789; }`,
 * uncomment this block, and point the alias at this st7789.
 */
&pinctrl {
    lcd_cam_default: lcd_cam_default {
        group1 {
            pinmux = <ESP32_PINMUX(39, ESP_NOSIG, ESP_LCD_DATA_OUT0)>,
                     <ESP32_PINMUX(40, ESP_NOSIG, ESP_LCD_DATA_OUT1)>,
                     <ESP32_PINMUX(41, ESP_NOSIG, ESP_LCD_DATA_OUT2)>,
                     <ESP32_PINMUX(42, ESP_NOSIG, ESP_LCD_DATA_OUT3)>,
                     <ESP32_PINMUX(45, ESP_NOSIG, ESP_LCD_DATA_OUT4)>,
                     <ESP32_PINMUX(46, ESP_NOSIG, ESP_LCD_DATA_OUT5)>,
                     <ESP32_PINMUX(47, ESP_NOSIG, ESP_LCD_DATA_OUT6)>,
                     <ESP32_PINMUX(48, ESP_NOSIG, ESP_LCD_DATA_OUT7)>,
                     <ESP32_PINMUX(8,  ESP_NOSIG, ESP_LCD_PCLK)>,       // WR
                     <ESP32_PINMUX(7,  ESP_NOSIG, ESP_LCD_DC)>;
            output-enable;
        };
    };
};

&lcd_cam {
    pinctrl-0 = <&lcd_cam_default>;
    pinctrl-names = "default";
    // lcd_cam already provides dmas = <&dma 6>, <&dma 7>; dma-names = "rx", "tx";
};

&lcd_cam_disp {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;

    reset-gpios = <&gpio0 5 GPIO_ACTIVE_LOW>;
    cs-gpios    = <&gpio0 6 GPIO_ACTIVE_LOW>;
    /* RD active-low: driven INACTIVE (physical high) at init so the panel
     * stops driving the shared 8080 data bus during writes. */
    rd-gpios    = <&gpio0 9 GPIO_ACTIVE_LOW>;

    st7789: st7789@0
    {
        compatible = "sitronix,st7789v";
        reg = <0>;                       // CS index (slave 0)
        mipi-max-frequency = <10000000>; // i80 PCLK
        mipi-mode = "MIPI_DBI_MODE_8080_BUS_8_BIT";

        pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;

        // DC line levels (driver defaults: idle/cmd=0, data=1)
        // dc-cmd-level  = <0>;
        // dc-data-level = <1>;

        height = <170>;
        width  = <320>;
        x-offset = <0>;
        y-offset = <35>;
        mdac = <0xa0>;

        vcom  = <0x19>;
        gctrl = <0x35>;
        vrhs  = <0x12>;
        vdvs  = <0x20>;
        gamma = <0x01>;
        lcm   = <0x2c>;
        porch-param   = [ 0c 0c 00 33 33 ];
        cmd2en-param  = [ 5a 69 02 01 ];
        pwctrl1-param = [ a4 a1 ];
        pvgam-param   = [ D0 04 0D 11 13 2B 3F 54 4C 18 0D 0B 1F 23 ];
        nvgam-param   = [ D0 04 0C 11 13 2C 3F 44 51 2F 1F 1F 20 23 ];
        ram-param     = [ 00 F8 ];
        rgb-param     = [ CD 08 14 ];
    };
};

&dma
{
    status = "okay";
};

&uart0
{
    status = "disabled";
    current-speed = <115200>;
};

&usb_serial
{
	status = "okay";
};

&ledc0 {
	pinctrl-0 = <&ledc0_default>;
	pinctrl-names = "default";
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	channel0@0 {
		reg = <0x0>;
		timer = <0>;
	};
};

&pinctrl {
	ledc0_default: ledc0_default {
		group1 {
			pinmux = <LEDC_CH0_GPIO38>;
			output-enable;
		};
	};
};
